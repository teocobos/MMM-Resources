#LAMMPS Input file generated by Avogadro
# SiO2

# Intialization
units          real
dimension      3d
boundary       p p p
atom_style     full

# Atom Definition
read_data      structure.xyz
replicate      1 1 1


# Settings
velocity       all create 300.00 4928459 rot yes mom yes dist gaussian
fix            ensemble all nvt temp 300.00 300.00 100 tchain 1

timestep       0.0

# Output
dump           dumpXYZ all xyz 1 final.xyz
thermo_style   one
thermo         50

# Run the simulation
run            20000

