  using 1 OpenMP thread(s) per MPI task
# minimal for python
# ---------- Initialize Simulation ---------------------
#variable alat equal 3.8848589
#variable xdim equal ${alat}*5
variable T1 equal 300
variable T2 equal 4000
variable tstep equal 0.001
variable runtime equal 1600000
variable Srandomseed equal 1001
variable NA  equal 6.02214179e23
clear
  using 1 OpenMP thread(s) per MPI task
units metal
dimension 3
boundary p p p
atom_style full
variable rho equal mass(all)/${NA}/(vol*1.0e-24)
variable rho equal mass(all)/6.02214179e+23/(vol*1.0e-24)
# ---------- Create Atomistic Structure ---------------------
read_data GaO.lmp
