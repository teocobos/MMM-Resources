  read_data CPU = 1.345 seconds
#region whole block 0 ${xdim} 0 ${xdim} 0 ${xdim} units box
#create_box 1 whole
#create_atoms 1 region whole
# ---------- Define Interatomic Potential ---------------------
pair_style buck/coul/long/cs 16
pair_coeff * * 0.0  1.0 0.0 # Other interactions set to zero
pair_coeff 1 2 907.89   0.345    10.000   # Gashel-Oshel
pair_coeff 2 2 22764.0  0.149    0.0  # Oshel-Oshel
kspace_style ewald 1.0E-5
#bond_style harmonic
#bond_coeff 1 3.15 0
neighbor 0.2 bin
#bond_style class2
timestep ${tstep}
timestep 0.001
#min_style cg
#minimize 1e-8 1e-8 1000 1000
#change_box all x scale 1.1 y volume z volume remap
# ----- perform MD -------
#velocity all create ${T2} ${Srandomseed}

thermo 1000
thermo_style custom step lx atoms temp pe lx ly lz press pxx pyy pzz vol v_rho
fix 1 all nvt temp ${T2} ${T2} 0.1
fix 1 all nvt temp 4000 ${T2} 0.1
fix 1 all nvt temp 4000 4000 0.1
fix 2 all press/berendsen iso 0.0 0.0 1000.0
dump 3 all xyz 1000 GaO_model.xyz
dump_modify 3 element Ga O
run 200000
