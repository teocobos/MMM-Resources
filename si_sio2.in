# Si/SiO2 run with ReaxFF
units           real

atom_style      charge
boundary	p f p  
read_data       si_sio2_data

pair_style      reaxff NULL
pair_coeff      * * ffield.reax Si O 
fix 1 all qeq/reax 1 0.0 10.0 1.0e-6 reaxff


variable density equal "(mass(all)*1.660538782) / (vol)"

region mybox block 0.0 INF 0.0 7.97 0.0 INF units box
group mybox region mybox

region mybox_upper block 0.0 INF 17.90 INF 0.0 INF units box
group mybox_upper region mybox_upper

group box_fix union mybox mybox_upper 
fix freze box_fix setforce 0.0 0.0 0.0 

group unfrozen subtract all box_fix


compute sio2 unfrozen temp
thermo 2000
thermo_style    custom step temp c_sio2 etotal pe ke evdwl ecoul press vol 
 
dump 1 all xyz 2000 si_sio2_md.xyz
dump 2 all custom 2000 si_sio2_md.cust id type x y z q   


fix refwall unfrozen wall/reflect ylo 7.96 yhi 17.90 units box 

fix 3 all nve
timestep 0.5
velocity unfrozen create 300.0 4928459 dist gaussian
fix 4 unfrozen temp/berendsen 300.0 300.0 0.1

run 10000

unfix 4
fix 4 unfrozen temp/berendsen 300.0 5000.0 1.0
run 60000
write_restart heatup.rst

unfix 4 
fix 4 unfrozen temp/berendsen 5000.0 5000.0 1.0
run 100000
write_restart heatup_equil.rst

unfix 4
fix 4 unfrozen temp/berendsen 5000.0 0.0 1.0
run 3000000
write_restart final.rst
